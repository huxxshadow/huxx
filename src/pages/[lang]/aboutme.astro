---
import Layout from "@/layouts/Base.astro";
import { useTranslations, type Lang, LOCALES } from "@/i18n";
import { navTranslations } from "@/i18n/components/Header_i18";

import DndAboutSection from "@/components/aboutme/DndAboutSection.astro";
import GameJourneySection from "@/components/aboutme/GameJourneySection.astro";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

export const getStaticPaths = () =>
    Object.keys(LOCALES).map((lang) => ({
        params: { lang },
    }));
---

<Layout title={t(navTranslations.about)} description="About Me">
    <DndAboutSection />
    <GameJourneySection />
</Layout>