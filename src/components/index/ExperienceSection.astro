---
// src/components/ExperienceSection.astro
import { useTranslations, type Lang } from "@/i18n.ts";
import { COLORS } from "@/consts.ts";
import { experienceListData } from "@/i18n/components/index/ExperienceSection_i18.ts";

// 引入 Logo 静态资源




const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

const defaultTheme = COLORS.blue;
const activeTheme = COLORS.purple;

// 将 i18n 数据转换为当前语言可用的扁平数据，方便 HTML 循环
const experiences = experienceListData.map(item => ({
    company: t(item.company),
    fullName: t(item.fullName),
    role: t(item.role),
    date: t(item.date),
    logo: item.logo,
    logoSize: item.logoSize,
    bullets: item.bullets.map(b => t(b)),
    tags: item.tags.map(tag => t(tag))
}));
---

<section
        id="experience-section"
        class="relative w-full overflow-hidden"
        data-theme-bg={activeTheme.light}
        data-theme-text={activeTheme.dark}
        style={`background-color: ${defaultTheme.light}; color: ${defaultTheme.dark};`}
>
    <div class="flex flex-col lg:flex-row w-full h-auto lg:h-[720px]">
        {experiences.map((exp, index) => (
                <div
                        class={`exp-card group cursor-pointer relative overflow-hidden transition-[flex,background-color] rounded-t-3xl duration-700 ease-[cubic-bezier(0.2,1,0.3,1)] ${index === 0 ? 'active lg:flex-[5]' : 'lg:flex-[1]'}`}
                        data-active-bg={activeTheme.light}
                        data-active-text={activeTheme.dark}
                        data-default-bg={defaultTheme.light}
                        data-default-text={defaultTheme.dark}
                        style={index === 0
                            ? `background-color: ${activeTheme.light}; color: ${activeTheme.dark};`
                            : `background-color: ${defaultTheme.light}; color: ${defaultTheme.dark};`}
                >
                    <div class="exp-collapsed-view flex flex-col items-center justify-center p-6 lg:p-6 transition-all duration-500 gap-0 w-full h-full">
                        <div
                                class={`${exp.logoSize} bg-current transition-transform duration-500 group-hover:scale-110 flex-shrink-0`}
                                style={`
                                mask: url(${exp.logo?.src || exp.logo}) no-repeat center / contain;
                                -webkit-mask: url(${exp.logo?.src || exp.logo}) no-repeat center / contain;
                                `}
                        ></div>
                        <h3 class="text-3xl lg:text-3xl font-black tracking-normal duration-500 group-hover:scale-110 text-center">
                            {exp.role}
                        </h3>
                    </div>

                    <div class="exp-expanded-view p-8 lg:p-12 flex flex-col opacity-0 pointer-events-none transition-all duration-500 translate-y-10 w-full h-full">
                        <div
                                class="absolute -bottom-20 right-20 w-80 h-150 lg:w-150 lg:h-150 bg-current opacity-5 pointer-events-none z-0"
                                style={`
                                mask: url(${exp.logo?.src || exp.logo}) no-repeat center right / contain;
                                -webkit-mask: url(${exp.logo?.src || exp.logo}) no-repeat center right / contain;
                                `}
                        ></div>

                        <div class="relative z-10 flex flex-col h-full">
                            <div class="flex items-center gap-6 mb-10">
                                <div>
                                    <h3 class="text-4xl lg:text-7xl font-black leading-none italic">{exp.company}</h3>
                                    <p class="text-lg lg:text-xl font-bold opacity-70 mt-3">{exp.fullName}</p>
                                </div>
                            </div>

                            <div class="flex flex-col lg:flex-row lg:items-end justify-between border-b-4 border-current pb-6 mb-10 gap-4">
                                <span class="text-3xl lg:text-5xl font-black">{exp.role}</span>
                                <span class="text-xl lg:text-2xl font-bold opacity-80">{exp.date}</span>
                            </div>

                            <ul class="flex flex-col gap-6 text-lg lg:text-2xl font-bold max-w-[95%] leading-tight">
                                {exp.bullets.map(bullet => (
                                        <li class="flex items-start gap-4">
                                            <span class="mt-2 w-3 h-3 rotate-45 bg-current flex-shrink-0"></span>
                                            <span>{bullet}</span>
                                        </li>
                                ))}
                            </ul>

                            {exp.tags && exp.tags.length > 0 && (
                                    <div class="mt-8 flex flex-wrap gap-3">
                                        {exp.tags.map(tag => (
                                                <span class="px-5 py-1.5 border-2 border-current rounded-full text-sm lg:text-lg font-bold bg-transparent">
                                                    {tag}
                                                </span>
                                        ))}
                                    </div>
                            )}
                        </div>
                    </div>
                </div>
        ))}
    </div>
</section>
<style>
    .exp-collapsed-view, .exp-expanded-view {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .exp-card.active .exp-collapsed-view {
        opacity: 0;
        transform: scale(0.8);
        pointer-events: none;
    }

    .exp-card.active .exp-expanded-view {
        opacity: 1;
        pointer-events: auto;
        transform: translateY(0);
        transition-delay: 300ms;
    }

    .exp-card:not(.active):hover {
        filter: brightness(0.97);
    }

    @media (max-width: 1024px) {
        .exp-card {
            flex: none !important;
            height: auto !important;
        }

        .exp-card:not(.active) .exp-collapsed-view {
            position: relative;
            min-height: 260px;
        }

        .exp-card:not(.active) .exp-expanded-view {
            position: absolute;
        }

        .exp-card.active .exp-collapsed-view {
            position: absolute;
        }

        .exp-card.active .exp-expanded-view {
            position: relative;
            height: auto;
            padding-bottom: 4rem;
        }
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const cards = document.querySelectorAll('.exp-card');
        const expSection = document.getElementById('experience-section');

        // ==========================================
        // 经验部分卡片展开逻辑
        // ==========================================
        cards.forEach(card => {
            card.addEventListener('click', () => {
                if (card.classList.contains('active')) return;

                const activeBg = card.getAttribute('data-active-bg');
                const activeText = card.getAttribute('data-active-text');

                cards.forEach(c => {
                    c.classList.remove('active', 'lg:flex-[5]');
                    c.classList.add('lg:flex-[1]');

                    const dBg = c.getAttribute('data-default-bg');
                    const dText = c.getAttribute('data-default-text');

                    (c as HTMLElement).style.backgroundColor = dBg || '';
                    (c as HTMLElement).style.color = dText || '';
                });

                card.classList.remove('lg:flex-[1]');
                card.classList.add('active', 'lg:flex-[5]');

                (card as HTMLElement).style.backgroundColor = activeBg || '';
                (card as HTMLElement).style.color = activeText || '';

                if (activeBg && activeText && expSection) {
                    const event = new CustomEvent('section-theme-change', {
                        detail: { bg: activeBg, text: activeText, source: expSection }
                    });
                    document.dispatchEvent(event);
                }
            });
        });
    });
</script>