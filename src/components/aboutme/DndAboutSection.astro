---
import { useTranslations, type Lang } from "@/i18n";
import { COLORS } from "@/consts";
import Avatar from "@/assets/avater.svg";

import {
    dndLabels,
    characterCardData,
    equipmentListData,
    traitListData,
    skillsLeftData,
    skillsRightData,
    spellBookData,
    mainQuestData,
    sideQuestsData,
    timelineData,
} from "@/i18n/components/aboutme/DndAboutSection_i18";

const locale = Astro.currentLocale as Lang;
const t = useTranslations(locale);

// ---- Flatten i18n data for template ----
const character = {
    name: characterCardData.name,
    alignment: t(characterCardData.alignment),
    race: t(characterCardData.race),
    stats: characterCardData.stats.map((s) => ({
        label: s.label,
        value: s.value,
        modifier: s.modifier,
        name: t(s.name),
    })),
    classes: characterCardData.classes.map((c) => ({
        name: t(c.name),
        level: c.level,
        progress: c.progress,
    })),
    hobbies: t(characterCardData.hobbies),
    likes: t(characterCardData.likes),
    favMusic: characterCardData.favMusic.map((m) => t(m)),
    favAnime: characterCardData.favAnime.map((a) => t(a)),
    personalityTitle: t(characterCardData.personalityTitle),
    personalityDesc1: t(characterCardData.personalityDesc1),
    personalityDesc2: t(characterCardData.personalityDesc2),
    quote: t(characterCardData.quote),
};

const equipments = equipmentListData.map((eq) => ({
    icon: eq.icon,
    col: eq.col,
    mt: eq.mt,
    name: t(eq.name),
    rarity: t(eq.rarity),
    stats: t(eq.stats),
    flavor: t(eq.flavor),
}));

const traits = traitListData.map((tr) => ({
    icon: tr.icon,
    name: t(tr.name),
    description: t(tr.description),
}));

const skillsLeft = skillsLeftData.map((s) => ({ modifier: s.modifier, name: t(s.name) }));
const skillsRight = skillsRightData.map((s) => ({ modifier: s.modifier, name: t(s.name) }));
const spellBook = spellBookData.map((lvl) => ({
    label: t(lvl.label),
    totalSlots: lvl.totalSlots,
    filledSlots: lvl.filledSlots,
    spells: lvl.spells.map((sp) => ({
        icon: sp.icon,
        name: sp.name,
        subtitle: t(sp.subtitle),
    })),
}));

const mainQuest = {
    icon: mainQuestData.icon,
    title: t(mainQuestData.title),
    description: t(mainQuestData.description),
    progress: mainQuestData.progress,
};

const sideQuests = sideQuestsData.map((sq) => ({
    icon: sq.icon,
    title: t(sq.title),
    progress: sq.progress,
}));

const timeline = timelineData.map((entry) => ({
    year: entry.year,
    title: t(entry.title),
    description: t(entry.description),
    isNow: entry.isNow ?? false,
}));
const classNameSize = (locale === "en" || locale === "ja") ? "text-sm" : "text-lg";
// ---- Layout helpers (not i18n) ----
function tooltipPos(col: number): string {
    if (col <= 1) return "left-0";
    if (col >= 5) return "right-0";
    return "left-1/2 -translate-x-1/2";
}

const colStartClass: Record<number, string> = {
    1: "col-start-1",
    2: "col-start-2",
    3: "col-start-3",
    4: "col-start-4",
    5: "col-start-5",
};

const showSpellSubtitle = locale !== "en";
---

<section
        class="relative overflow-hidden w-full px-4 sm:px-6 pt-8 pb-48  flex flex-col"
        style={`background-color: ${COLORS.red.light}; color: ${COLORS.red.dark};`}
        data-theme-bg={COLORS.red.light}
        data-theme-text={COLORS.red.dark}
>
    <!-- ========== Full-Width D&D Header ========== -->
    <div class="relative z-10 w-full mb-6 lg:mb-8">
        <div class="flex items-center gap-3 mb-4">
            <div class="h-0.5 flex-1 bg-current/20 rounded-full"></div>
            <i class="fa-solid fa-dice-d20 text-sm opacity-30"></i>
            <div class="h-0.5 w-8 bg-current/40 rounded-full"></div>
            <i class="fa-solid fa-dragon text-sm opacity-30"></i>
            <div class="h-0.5 w-8 bg-current/40 rounded-full"></div>
            <i class="fa-solid fa-dice-d20 text-sm opacity-30"></i>
            <div class="h-0.5 flex-1 bg-current/20 rounded-full"></div>
        </div>

        <div class="flex flex-col items-center gap-1">
            <h2 class="text-5xl font-black tracking-widest uppercase opacity-90">
                {t(dndLabels.sectionTitle)}
            </h2>
            <span class="text-base font-bold tracking-widest uppercase opacity-40">
            {t(dndLabels.sectionSubtitle)}
        </span>
        </div>

        <div class="flex items-center gap-3 mt-4">
            <div class="h-0.5 flex-1 bg-current/20 rounded-full"></div>
            <div class="w-2 h-2 rotate-45 border border-current/30 bg-current/10"></div>
            <div class="h-px w-12 bg-current/30"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-current/40"></div>
            <div class="h-px w-12 bg-current/30"></div>
            <div class="w-2 h-2 rotate-45 border border-current/30 bg-current/10"></div>
            <div class="h-0.5 flex-1 bg-current/20 rounded-full"></div>
        </div>
    </div>
    <div class="flex flex-col lg:flex-row w-full">
        <!-- ========== Column 1: Character Card ========== -->
        <div class="relative z-10 w-full lg:w-2/6 flex flex-col border-r-0 lg:border-r border-current/20 pr-0 lg:pr-6 mb-8 lg:mb-0">

            <div class="flex flex-col lg:flex-row gap-4 lg:min-h-[380px] lg:flex-shrink-0">

                <div class="w-full lg:w-[300px] relative flex flex-col rounded-xl overflow-hidden border-2 border-current/30 bg-current/5 shadow-sm">
                    <div class="w-full text-center pt-4 pb-2">
                        <span class="text-5xl lg:text-5xl font-black opacity-90">{character.name}</span>
                    </div>
                    <div class="flex-1 w-full flex items-center justify-center relative">
                        <Avatar class="w-full h-auto opacity-70 block drop-shadow-md" fill="currentColor" />
                    </div>
                </div>

                <div class="flex-1 min-w-0 flex flex-col lg:h-full justify-between py-1">

                    <div class="w-full text-center pb-2 border-b-2 border-current/20 mb-3">
                        <span class="text-2xl font-black tracking-widest uppercase opacity-90">{character.alignment}</span>
                    </div>

                    <div class="flex-1 flex flex-col mb-3">
                        <div class="flex items-center justify-center gap-2 mb-2 text-xl font-bold opacity-80">
                            <i class="fa-solid fa-mars"></i>
                            <span>{character.race}</span>
                        </div>

                        <div class="bg-current/5 rounded-md p-2">
                            <table class="w-full text-left text-base">
                                <tbody class="divide-y divide-current/10">
                                {character.stats.map((stat) => (
                                        <tr class="hover:bg-current/10 transition-colors">
                                            <td class="py-1 font-bold opacity-70">
                                                {stat.label}
                                                {stat.name && (
                                                        <span class="text-xs font-normal opacity-50 ml-1">{stat.name}</span>
                                                )}
                                            </td>
                                            <td class="font-black text-center">{stat.value}</td>
                                            <td class="text-right font-bold">{stat.modifier}</td>
                                        </tr>
                                ))}
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2 pt-3 border-current/20">
                        <div class="flex flex-col gap-4 w-full pr-4">
                            {character.classes.map((cls) => (
                                    <div class="flex flex-col gap-1.5">
                                        <div class="flex justify-between items-end gap-2">
                                            <span class:list={[classNameSize, "font-bold leading-none whitespace-nowrap"]}>{cls.name}</span>
                                            <span class="text-xs font-black opacity-60 tracking-widest flex-shrink-0">{cls.level}</span>
                                        </div>
                                        <div class="w-full h-1 bg-current/10 rounded-full overflow-hidden">
                                            <div class="h-full bg-current opacity-80" style={`width: ${cls.progress}%;`}></div>
                                        </div>
                                    </div>
                            ))}
                        </div>
                    </div>

                </div>
            </div>

            <div class="mt-6 lg:flex-1 border border-current/30 rounded-xl bg-current/5 p-5 flex flex-col gap-4">

                <div class="grid grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1">
                        <div class="flex items-center gap-1.5">
                            <i class="fa-solid fa-dice-d20 text-xs opacity-60"></i>
                            <span class="text-sm font-black uppercase tracking-widest opacity-60">{t(dndLabels.hobbiesLabel)}</span>
                        </div>
                        <span class="text-base font-bold leading-tight opacity-90 pl-1">{character.hobbies}</span>
                    </div>

                    <div class="flex flex-col gap-1">
                        <div class="flex items-center gap-1.5">
                            <i class="fa-solid fa-heart text-xs opacity-60"></i>
                            <span class="text-sm font-black uppercase tracking-widest opacity-60">{t(dndLabels.likesLabel)}</span>
                        </div>
                        <span class="text-base font-bold leading-tight opacity-90 pl-1">{character.likes}</span>
                    </div>
                </div>

                <div class="h-px w-full bg-current/10"></div>

                <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-1.5">
                        <i class="fa-solid fa-headphones text-xs opacity-60"></i>
                        <span class="text-sm font-black uppercase tracking-widest opacity-60">{t(dndLabels.favMusicLabel)}</span>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-0.5 pl-1 opacity-90">
                        {character.favMusic.map((m) => (
                                <span class="text-base font-medium underline decoration-current/30 underline-offset-4">{m}</span>
                        ))}
                    </div>
                </div>

                <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-1.5">
                        <i class="fa-solid fa-tv text-xs opacity-60"></i>
                        <span class="text-sm font-black uppercase tracking-widest opacity-60">{t(dndLabels.favAnimeLabel)}</span>
                    </div>
                    <div class="flex flex-wrap items-center gap-2 mt-0.5 pl-1 opacity-90">
                        {character.favAnime.map((a) => (
                                <span class="text-base font-medium underline decoration-current/30 underline-offset-4">{a}</span>
                        ))}
                    </div>
                </div>

            </div>

            <div class="lg:flex-1 mt-6 border border-current/30 rounded-xl bg-current/5 p-5 flex flex-col gap-4">
                <div class="flex flex-col gap-1">
                    <p class="text-lg font-bold leading-tight pl-1">
                        {character.personalityTitle}
                    </p>
                    <p class="text-xs leading-relaxed opacity-80 pl-1 mt-1">{character.personalityDesc1}</p>
                    <p class="text-xs leading-relaxed opacity-80 pl-1">{character.personalityDesc2}</p>
                </div>

                <div class="h-px w-full bg-current/10"></div>

                <div class="flex flex-col gap-1">
                    <p class="text-sm italic font-medium leading-relaxed border-l-2 border-current/30 pl-3 py-0.5 opacity-90">
                        {character.quote}
                    </p>
                </div>
            </div>

        </div>

        <!-- ========== Column 2: Equipment + Traits ========== -->
        <div class="relative z-10 w-full lg:w-5/24 flex flex-col pl-0 lg:pl-10 pt-8 lg:pt-0">


            <h3 class="text-xl font-bold mb-4 hidden lg:flex items-center gap-2 opacity-90">
                <i class="fa-solid fa-crosshairs"></i> {t(dndLabels.equipmentHeader)}
            </h3>

            <div class="flex-1 border border-current/30 rounded-xl bg-current/5 p-4 mb-6 shadow-inner relative hidden lg:flex flex-col">
                <div class="flex-1 grid grid-cols-5 gap-y-3 gap-x-2 relative z-10" style="grid-auto-rows: 1fr;">
                    {equipments.map((eq) => (
                            <div class:list={[
                                colStartClass[eq.col],
                                eq.mt && "translate-y-4",
                                "group relative hover:z-50"
                            ]}>
                                <div class="relative w-full h-full border-2 border-current/20 rounded bg-current/5 flex items-center justify-center hover:bg-current/10 hover:border-current/60 transition-all cursor-help">
                                    <i class:list={[eq.icon, "text-lg opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all"]} />

                                    <div
                                            class:list={[
                                                "absolute top-full mt-2 w-max p-2.5 rounded-lg border-2 border-current/30 shadow-md",
                                                "opacity-0 group-hover:opacity-100 pointer-events-none transition-all z-50 group-hover:translate-y-1",
                                                tooltipPos(eq.col),
                                            ]}
                                            style={`background-color: ${COLORS.white};`}
                                    >
                                        <div class="h-0.5 w-full bg-current/60 rounded-full mb-2" />
                                        <p class="font-bold text-base whitespace-nowrap">{eq.name}</p>
                                        <p class="text-sm opacity-50 mb-1.5">{eq.rarity}</p>
                                        <p class="text-sm opacity-70 max-w-60">{eq.stats}</p>
                                        <p class="text-xs italic opacity-50 mt-1.5 leading-relaxed max-w-60">{eq.flavor}</p>
                                    </div>
                                </div>
                            </div>
                    ))}
                </div>
            </div>

            <h3 class="text-xl font-bold mb-4 flex items-center gap-2 opacity-90">
                <i class="fa-solid fa-wand-magic-sparkles"></i> {t(dndLabels.traitsHeader)}
            </h3>

            <div class="border border-current/30 rounded-xl bg-current/5 p-5 flex flex-col gap-5">
                <div class="flex flex-col gap-4">
                    {traits.map((trait) => (
                            <div class="flex items-start gap-3 group">
                                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-current/10 flex items-center justify-center group-hover:bg-current/20 transition-colors">
                                    <i class:list={[trait.icon, "text-xl"]} />
                                </div>
                                <div class="flex flex-col">
                                    <span class="font-bold text-base leading-none mb-1.5">{trait.name}</span>
                                    <p class="text-xs opacity-70 leading-relaxed">{trait.description}</p>
                                </div>
                            </div>
                    ))}
                </div>
            </div>

        </div>

        <!-- ========== Column 3: Feats + Skills + Spell Book ========== -->
        <div class="relative z-10 w-full lg:w-7/24 flex flex-col gap-6 pl-0 lg:pl-10 pt-8 lg:pt-0">

            <!-- Feats Table -->
            <div class="flex flex-col">
                <h3 class="text-xl font-bold mb-4 flex items-center gap-2 opacity-90">
                    <i class="fa-solid fa-dice-d20"></i> {t(dndLabels.featsHeader)}
                </h3>
                <div class="flex border border-current/20 rounded-xl overflow-hidden bg-current/5">
                    <table class="w-1/2 text-left text-sm font-bold">
                        <tbody class="divide-y divide-current/10">
                        {skillsLeft.map((s) => (
                                <tr>
                                    <td class="py-2.5 pl-4 pr-2 font-black text-base w-12 text-right">{s.modifier}</td>
                                    <td class="py-2.5 px-2">{s.name}</td>
                                </tr>
                        ))}
                        </tbody>
                    </table>
                    <div class="w-px bg-current/20"></div>
                    <table class="w-1/2 text-left text-sm font-bold">
                        <tbody class="divide-y divide-current/10">
                        {skillsRight.map((s) => (
                                <tr>
                                    <td class="py-2.5 pl-4 pr-2 font-black text-base w-12 text-right">{s.modifier}</td>
                                    <td class="py-2.5 px-2">{s.name}</td>
                                </tr>
                        ))}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Spell Book -->
            <div class="flex flex-col flex-1">
                <h3 class="text-xl font-bold mb-4 flex items-center gap-2 opacity-90">
                    <i class="fa-solid fa-wand-sparkles"></i> {t(dndLabels.grimoireHeader)}
                </h3>
                <div class="border border-current/20 rounded-xl overflow-hidden bg-current/5 flex-1 flex flex-col">

                    <!-- Spell table header -->
                    <div class="flex items-center justify-between px-4 py-2 bg-current/10 border-b border-current/15">
                        <span class="text-sm font-black uppercase tracking-widest opacity-50">{t(dndLabels.spellLabel)}</span>
                        <span class="text-sm font-black uppercase tracking-widest opacity-50">{t(dndLabels.slotsLabel)}</span>
                    </div>

                    <table class="w-full text-left text-sm flex-1">
                        <tbody class="divide-y divide-current/10">

                        {spellBook.map((level) => (
                                <>
                                    {/* Level Header */}
                                    <tr class="bg-current/5">
                                        <td colspan={level.totalSlots > 0 ? "3" : "4"} class="py-1.5 px-4">
                                            <span class="text-[11px] font-black uppercase tracking-widest opacity-40">▸ {level.label}</span>
                                        </td>
                                        {level.totalSlots > 0 && (
                                                <td class="py-1.5 pr-4 text-right">
                                                <span class="inline-flex gap-1">
                                                    {Array.from({ length: level.totalSlots }).map((_, i) => (
                                                            <span class:list={[
                                                                "w-2 h-2 rounded-full bg-current inline-block",
                                                                i < level.filledSlots ? "opacity-70" : "opacity-20",
                                                            ]}></span>
                                                    ))}
                                                </span>
                                                </td>
                                        )}
                                    </tr>

                                    {/* Spell Rows (2 spells per row) */}
                                    {Array.from({ length: Math.ceil(level.spells.length / 2) }).map((_, rowIdx) => {
                                        const sp1 = level.spells[rowIdx * 2];
                                        const sp2 = level.spells[rowIdx * 2 + 1];
                                        return (
                                                <tr class="hover:bg-current/10 transition-colors">
                                                    <td class="py-2 pl-4 pr-2 w-8"><i class:list={[sp1.icon, "text-xs opacity-60"]} /></td>
                                                    <td class="py-2 font-bold">
                                                        {sp1.name}
                                                        {showSpellSubtitle && (
                                                                <span class="text-xs font-normal opacity-50 ml-1">{sp1.subtitle}</span>
                                                        )}
                                                    </td>
                                                    {sp2 ? (
                                                            <>
                                                                <td class="py-2 pr-2 w-8"><i class:list={[sp2.icon, "text-xs opacity-60"]} /></td>
                                                                <td class="py-2 font-bold pr-4">
                                                                    {sp2.name}
                                                                    {showSpellSubtitle && (
                                                                            <span class="text-xs font-normal opacity-50 ml-1">{sp2.subtitle}</span>
                                                                    )}
                                                                </td>
                                                            </>
                                                    ) : (
                                                            <>
                                                                <td class="py-2 pr-2 w-8"></td>
                                                                <td class="py-2 pr-4"></td>
                                                            </>
                                                    )}
                                                </tr>
                                        );
                                    })}
                                </>
                        ))}

                        </tbody>
                    </table>
                </div>
            </div>

        </div>

        <!-- ========== Column 4: Quest Log + Timeline ========== -->
        <div class="relative z-10 w-full lg:w-4/24 flex flex-col gap-6 border-t lg:border-t-0 border-current/20 pt-8 lg:pt-0 lg:pl-8">

            <!-- Quest Log -->
            <div class="flex flex-col gap-3">
                <h3 class="text-xl font-bold flex items-center gap-2 opacity-90">
                    <i class="fa-solid fa-list-check"></i> {t(dndLabels.questsHeader)}
                </h3>

                <!-- Main Quest -->
                <div class="border border-current/20 rounded-lg px-4 py-3 bg-current/5 flex flex-col gap-2">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <i class:list={[mainQuest.icon, "text-xs opacity-50"]}></i>
                            <span class="font-black text-base">{mainQuest.title}</span>
                        </div>
                        <span class="text-sm font-black opacity-40 border border-current/20 px-1.5 py-0.5 rounded">{t(dndLabels.mainQuestTag)}</span>
                    </div>
                    <p class="text-xs opacity-70 leading-relaxed">{mainQuest.description}</p>
                    <div class="flex items-center gap-2">
                        <div class="flex-1 bg-current/10 rounded-full h-1.5 overflow-hidden">
                            <div class="bg-current h-full rounded-full opacity-60" style={`width: ${mainQuest.progress}%`}></div>
                        </div>
                        <span class="text-xs font-black opacity-40">{mainQuest.progress}%</span>
                    </div>
                </div>

                <!-- Side Quests -->
                {sideQuests.map((sq) => (
                        <div class="border border-current/15 rounded-lg px-4 py-3 bg-current/5 flex flex-col gap-2">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-2">
                                    <i class:list={[sq.icon, "text-xs opacity-50"]}></i>
                                    <span class="font-bold text-sm">{sq.title}</span>
                                </div>
                                <span class="text-xs font-black opacity-40">{sq.progress}%</span>
                            </div>
                        </div>
                ))}
            </div>

            <!-- Adventure Timeline -->
            <div class="flex flex-col gap-4 mt-2">
                <h3 class="text-xl font-bold flex items-center gap-2 opacity-90">
                    <i class="fa-solid fa-timeline"></i> {t(dndLabels.adventureHeader)}
                </h3>
                <div class="flex items-center gap-2">
                    <div class="h-px bg-current/20 flex-1"></div>
                </div>

                <div class="relative pl-5 border-l-2 border-current/15 flex flex-col gap-0">

                    {timeline.map((entry) => (
                            <div class:list={["relative group", entry.isNow ? "" : "pb-6"]}>
                                <div class:list={[
                                    "absolute -left-[calc(1.25rem+5px)] top-0.5 w-2.5 h-2.5 rounded-full",
                                    entry.isNow
                                        ? "bg-current ring-2 ring-current/20 animate-pulse"
                                        : "bg-current/80 ring-2 ring-current/10 group-hover:ring-current/30 transition-all",
                                ]}></div>
                                <span class="text-[10px] font-black tracking-widest opacity-40">{entry.year}</span>
                                <p class="text-sm font-bold leading-tight mt-0.5">
                                    {entry.title}
                                    {entry.isNow && (
                                            <span class="inline-block w-1 h-3.5 bg-current opacity-50 animate-pulse ml-0.5 align-text-bottom"></span>
                                    )}
                                </p>
                                <p class="text-[11px] opacity-60 leading-relaxed mt-0.5">{entry.description}</p>
                            </div>
                    ))}

                </div>
            </div>

        </div>
    </div>
</section>