---
import { LOCALES, getLocalePaths, type Lang, useTranslations } from "@/i18n";
import { getRelativeLocaleUrl } from "astro:i18n";
import Avatar from "@/assets/avater.svg";
import { SOCIALS, COLORS } from "@/consts";
import { navTranslations, headerTooltipsTranslations } from "@/i18n/components/Header_i18";

interface Props {
    bgColor?: string;
    textColor?: string;
}

const {
    bgColor = COLORS.green.light,
    textColor = COLORS.green.dark,
} = Astro.props;

const currentLocale = (Astro.currentLocale || "en") as Lang;
const localePaths = getLocalePaths(Astro.url);
const getPath = (path: string) => getRelativeLocaleUrl(currentLocale, path);
const t = useTranslations(currentLocale);

const NAV_LINKS = [
    { label: t(navTranslations.home), path: "/" },
    { label: t(navTranslations.blog), path: "/blog" },
    { label: t(navTranslations.portfolio), path: "/portfolio" },
    { label: t(navTranslations.about), path: "/about" },
];
---

<header
        style={`--hdr-bg: ${bgColor}; --hdr-text: ${textColor};`}
        class="sticky top-0 z-30 w-full flex items-center justify-between px-2 sm:px-3 pt-0 font-sans"
>
    <div class="flex items-center gap-2 sm:gap-4">
        <div class="h-16 sm:h-20 lg:h-28 shrink-0 flex items-center">
            <Avatar class="h-full w-auto block" fill="currentColor" />
        </div>

        <div class="flex flex-col justify-center gap-0.5 sm:gap-1">

            <div class="flex items-baseline gap-2 sm:gap-4">
                <a href={getPath("/")} class="nav-link-animated text-[1.5rem] sm:text-[2rem] lg:text-[2.7rem] font-black tracking-wider leading-none">
                    huxx
                </a>

                <div class="hidden lg:block w-1 h-10 bg-current rounded-sm self-center"></div>

                <nav class="hidden lg:flex items-baseline gap-3 text-[2.1rem]">
                    {
                        SOCIALS.map((item) => (
                                <a
                                        href={item.href}
                                        class="social-link hover:opacity-80 transition-opacity"
                                        aria-label={item.name}
                                >
                                    <i class={`fa-brands ${item.icon}`}></i>
                                </a>
                        ))
                    }
                </nav>
            </div>

            <div class="flex items-center gap-1.5 sm:gap-3 flex-wrap sm:flex-nowrap">
                {/* ——— Level 显示 + Tooltip ——— */}
                <div class="relative group flex items-center cursor-help">
                    <span id="player-level" class="font-bold text-sm sm:text-base tracking-wider">Lv 0</span>

                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                        <div class="hdr-tooltip-reversed px-3 py-1.5 text-xs rounded-md shadow-md whitespace-nowrap font-medium">
                            {t(headerTooltipsTranslations.levelTooltip)}
                        </div>
                    </div>
                </div>

                {/* ——— EXP 进度条 + Tooltip ——— */}
                <div class="relative group flex items-center w-16 sm:w-24 lg:w-32 h-2.5 cursor-help">
                    <div class="absolute inset-0 rounded-full opacity-20 hdr-bg-text"></div>
                    <div id="player-exp-bar" class="absolute left-0 top-0 h-full rounded-full transition-all duration-500 ease-out hdr-bg-text" style="width: 0%;"></div>

                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                        <div class="hdr-tooltip-reversed px-3 py-1.5 text-xs rounded-md shadow-md whitespace-nowrap font-medium flex items-center gap-1">
                            <span id="player-exp-text">{t(headerTooltipsTranslations.expTooltipPrefix)} 0 / 10</span>
                        </div>
                    </div>
                </div>

                {/* ——— EXP 速率 ——— */}
                <div id="player-exp-rate" class="font-mono text-sm sm:text-base font-semibold opacity-80 tracking-tight">
                    +1{t(headerTooltipsTranslations.expRateSuffix)}
                </div>

                {/* ——— Pong 勋章 ——— */}
                <div id="pong-badge-wrapper" data-lang={currentLocale} class="hidden relative group items-center cursor-help">
                    <span
                            class="hdr-tooltip-reversed flex items-center gap-1 sm:gap-1.5 px-2 sm:px-3 py-0.5 text-sm sm:text-base tracking-wide font-semibold rounded-md shadow-sm w-max"
                    >
                        <i class="fa-solid fa-table-tennis-paddle-ball text-xs sm:text-sm"></i>
                        <span>Pong</span>
                    </span>

                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                        <div class="hdr-tooltip-reversed px-3 py-2 text-xs rounded-md shadow-md whitespace-nowrap flex flex-col gap-1 font-medium">
                            <div id="pong-tooltip-name" class="font-bold border-b border-current/20 pb-1"></div>
                            <div id="pong-tooltip-bonus" class="opacity-90"></div>
                            <div id="pong-tooltip-desc" class="opacity-75 italic text-[11px]"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

    </div>

    {/* ——— 桌面端导航 ——— */}
    <div class="hidden lg:flex items-center gap-6 text-2xl font-semibold mr-5">
        {
            NAV_LINKS.map((link) => (
                    <a
                            href={getPath(link.path)}
                            class="relative nav-link-animated px-1"
                    >
                        {link.label}
                    </a>
            ))
        }

        <div class="relative group">
            <button class="relative nav-link-animated flex items-center gap-1 py-2 cursor-pointer" aria-label="Language options">
                <span>{LOCALES[currentLocale].label}</span>
                <i class="fa-solid fa-chevron-down text-xs ml-1"></i>
            </button>

            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50">
                <div class="hdr-dropdown flex flex-col shadow-sm rounded-sm py-2">
                    {
                        localePaths.map((lp) => (
                                <a
                                        href={lp.path}
                                        class="px-5 py-2 hover:bg-black/5 transition-colors text-center whitespace-nowrap"
                                >
                                    {LOCALES[lp.lang].label}
                                </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    {/* ——— 手机端菜单按钮 ——— */}
    <button
            id="mobile-menu-btn"
            class="lg:hidden relative z-50 text-2xl sm:text-3xl pr-2 focus:outline-none cursor-pointer"
            aria-label="Toggle Menu"
    >
        <i class="fa-solid fa-bars transition-transform duration-300"></i>
    </button>

    {/* ——— 手机端全屏菜单 ——— */}
    <div
            id="mobile-menu"
            class="hdr-dropdown fixed inset-0 z-40 translate-x-full transition-transform duration-300 flex flex-col items-center justify-center gap-8 text-2xl font-semibold"
    >
        {
            NAV_LINKS.map((link) => (
                    <a href={getPath(link.path)} class="relative nav-link-animated px-1 text-3xl">
                        {link.label}
                    </a>
            ))
        }

        <div class="w-16 h-[2px] bg-current opacity-30 my-2"></div>

        <div class="flex flex-col items-center gap-4 text-xl">
            <span class="opacity-70 text-sm tracking-widest uppercase"><i class="fa-solid fa-globe mr-1"></i> Language</span>
            <div class="flex gap-4">
                {
                    localePaths.map((lp) => (
                            <a
                                    href={lp.path}
                                    class={`px-1 transition-opacity ${
                                        lp.lang === currentLocale
                                            ? 'border-b-2 border-current opacity-100 font-bold'
                                            : 'opacity-50 hover:opacity-100'
                                    }`}
                            >
                                {LOCALES[lp.lang].label}
                            </a>
                    ))
                }
            </div>
        </div>

        <div class="flex gap-6 mt-8 text-[2.5rem]">
            {
                SOCIALS.map((item) => (
                        <a href={item.href} class="social-link hover:opacity-80 transition-opacity" aria-label={item.name}>
                            <i class={`fa-brands ${item.icon}`}></i>
                        </a>
                ))
            }
        </div>
    </div>
</header>

{/* ——— 全局样式：注册 CSS 自定义属性 ——— */}
<style is:global>
    @property --hdr-bg {
        syntax: '<color>';
        inherits: true;
        initial-value: #BDF1CD;
    }
    @property --hdr-text {
        syntax: '<color>';
        inherits: true;
        initial-value: #16A062;
    }
</style>

<style>
    header {
        background-color: var(--hdr-bg);
        color: var(--hdr-text);
        transition: --hdr-bg 0.7s ease, --hdr-text 0.7s ease;
    }
    .hdr-tooltip-reversed {
        background-color: var(--hdr-text);
        color: var(--hdr-bg);
    }
    .hdr-bg-text {
        background-color: var(--hdr-text);
    }
    .hdr-dropdown {
        background-color: var(--hdr-bg);
        color: var(--hdr-text);
    }
    .social-link:hover i {
        animation: fa-bounce 1s infinite;
        animation-timing-function: cubic-bezier(0.28, 0.84, 0.42, 1);
    }
    .nav-link-animated {
        position: relative;
        text-decoration: none;
    }
    .nav-link-animated::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: -2px;
        left: 0;
        background-color: currentColor;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nav-link-animated:hover::after {
        transform: scaleX(1);
        transform-origin: left;
    }
</style>

<script>
    import { PONG_BADGE_DATA, getRequiredExp } from "@/consts/Header";
    import { badgeTranslations, headerTooltipsTranslations } from "@/i18n/components/Header_i18";
    import { COLORS } from "@/consts";
    import type { Lang } from "@/i18n";

    document.addEventListener('astro:page-load', () => {
        const header = document.querySelector('header');
        const uiLevel = document.getElementById('player-level');
        const uiExpBar = document.getElementById('player-exp-bar');
        const uiExpText = document.getElementById('player-exp-text');
        const uiExpRate = document.getElementById('player-exp-rate');

        const badgeWrapper = document.getElementById('pong-badge-wrapper');
        const tooltipName = document.getElementById('pong-tooltip-name');
        const tooltipBonus = document.getElementById('pong-tooltip-bonus');
        const tooltipDesc = document.getElementById('pong-tooltip-desc');

        if (!header || !uiLevel || !uiExpBar || !uiExpText || !uiExpRate) return;

        const controller = new AbortController();
        const { signal } = controller;

        // ——— 语言环境 ———
        const lang = (badgeWrapper?.getAttribute('data-lang') as Lang) || 'en';
        const tPong = badgeTranslations.pong;
        const tHeader = headerTooltipsTranslations;

        const getExpPrefix = () => tHeader.expTooltipPrefix[lang] || tHeader.expTooltipPrefix['en'] || 'EXP:';
        const getExpRateSuffix = () => tHeader.expRateSuffix[lang] || tHeader.expRateSuffix['en'] || '/s';

        // ——— 挂机数据 ———
        let playerLevel = parseInt(localStorage.getItem('idle_playerLevel') || '0', 10);
        let playerExp = parseInt(localStorage.getItem('idle_playerExp') || '0', 10);

        let pongLevel = parseInt(localStorage.getItem('pongLevel') || sessionStorage.getItem('pongLevel') || '1', 10);
        let pongHasStarted = localStorage.getItem('pongHasStarted') === 'true' || sessionStorage.getItem('pongHasStarted') === 'true';

        let pongBadgeLv = pongHasStarted ? Math.min(pongLevel, 6) : 0;
        let requiredExp = getRequiredExp(playerLevel);

        const calculateExpRate = () => {
            let rate = 1;
            if (pongBadgeLv > 0 && PONG_BADGE_DATA[pongBadgeLv]) {
                rate += PONG_BADGE_DATA[pongBadgeLv].bonusRate;
            }
            return rate;
        };

        let expPerSec = calculateExpRate();

        // ============================================
        // ===== 内容驱动的 Header 主题色系统 (高灵敏度版) =====
        // ============================================

        const applyHeaderTheme = (bg: string, text: string) => {
            header.style.setProperty('--hdr-bg', bg);
            header.style.setProperty('--hdr-text', text);
        };

        // 获取页面中所有的主题区域 (querySelectorAll 返回的顺序就是 DOM 从上到下的顺序)
        const themeSections = Array.from(document.querySelectorAll('[data-theme-bg]'));
        let activeThemeSection: Element | null = null;
        let isScrolling = false;

        // 重新判定当前正垫在 Header 下方的区域
        const syncActiveSection = () => {
            if (themeSections.length === 0) return;

            // 设定触发线：大约是 Header 的高度加上少许缓冲（约 100px）
            const TRIGGER_Y = 100;
            let currentSection: Element | null = null;

            // 倒序遍历：找到 DOM 中最后一个顶部触及或越过触发线的元素
            for (let i = themeSections.length - 1; i >= 0; i--) {
                const rect = themeSections[i].getBoundingClientRect();
                if (rect.top <= TRIGGER_Y) {
                    currentSection = themeSections[i];
                    break;
                }
            }

            // 兜底：如果页面在最顶部，所有的元素的 top 都大于触发线，就默认取第一个
            if (!currentSection) {
                currentSection = themeSections[0];
            }

            // 发现需要切换主题时才执行，避免冗余重绘
            if (currentSection !== activeThemeSection) {
                activeThemeSection = currentSection;
                const bg = currentSection.getAttribute('data-theme-bg');
                const text = currentSection.getAttribute('data-theme-text');
                if (bg && text) applyHeaderTheme(bg, text);
            }

            isScrolling = false;
        };

        // 替换掉 IntersectionObserver，使用 scroll + rAF 实现帧级灵敏度
        if (themeSections.length > 0) {
            document.addEventListener('scroll', () => {
                if (!isScrolling) {
                    window.requestAnimationFrame(syncActiveSection);
                    isScrolling = true;
                }
            }, { passive: true, signal }); // 绑定了 signal，页面卸载时自动清理
        }

        // 监听内容区域的动态主题变化事件（如 Pong 升级换色）
        document.addEventListener('section-theme-change', ((e: CustomEvent) => {
            const { bg, text, source } = e.detail || {};
            if (!bg || !text || !(source instanceof Element)) return;

            source.setAttribute('data-theme-bg', bg);
            source.setAttribute('data-theme-text', text);

            // 如果触发更新的正是当前激活的区域，或者尚未初始化，直接应用
            if (source === activeThemeSection || !activeThemeSection) {
                activeThemeSection = source;
                applyHeaderTheme(bg, text);
            }
        }) as EventListener, { signal });

        // ——— 统一 UI 刷新 ———
        const updateUI = () => {
            uiLevel.innerText = `Lv ${playerLevel}`;
            uiExpBar.style.width = `${Math.min((playerExp / requiredExp) * 100, 100)}%`;
            uiExpText.innerText = `${getExpPrefix()} ${playerExp} / ${requiredExp}`;
            uiExpRate.innerText = `+${expPerSec}${getExpRateSuffix()}`;

            if (badgeWrapper && tooltipName && tooltipBonus && tooltipDesc) {
                if (pongBadgeLv > 0 && PONG_BADGE_DATA[pongBadgeLv]) {
                    const data = PONG_BADGE_DATA[pongBadgeLv];
                    const i18nLevel = tPong.levels[pongBadgeLv];

                    badgeWrapper.classList.remove('hidden');
                    badgeWrapper.classList.add('flex');

                    tooltipName.innerText = i18nLevel.name[lang] || i18nLevel.name['en'];

                    const bonusPrefix = tPong.bonusPrefix[lang] || tPong.bonusPrefix['en'];
                    const unit = tPong.unit[lang] || tPong.unit['en'];
                    tooltipBonus.innerText = `${bonusPrefix}${data.bonusRate}${unit}`;

                    tooltipDesc.innerText = i18nLevel.desc[lang] || i18nLevel.desc['en'];
                } else {
                    badgeWrapper.classList.add('hidden');
                    badgeWrapper.classList.remove('flex');
                }
            }
        };

        // ——— 首次渲染：跳过过渡，精准应用当前位置的区域颜色 ———
        header.style.transition = 'none';
        syncActiveSection();  // 直接测算当前滚动位置对应的颜色
        updateUI();

        void header.offsetHeight;
        // 用 rAF 延迟恢复过渡，给其他脚本（PongGame）一帧时间完成初始化
        requestAnimationFrame(() => {
            header.style.transition = '';
        });

        updateUI();
        void header.offsetHeight;

        // 用 rAF 延迟恢复过渡，给其他脚本（PongGame）一帧时间完成初始化
        requestAnimationFrame(() => {
            header.style.transition = '';
        });

        // ——— 每秒挂机循环 ———
        const gameLoop = setInterval(() => {
            playerExp += expPerSec;
            while (playerExp >= requiredExp) {
                playerExp -= requiredExp;
                playerLevel++;
                requiredExp = getRequiredExp(playerLevel);
                localStorage.setItem('idle_playerLevel', playerLevel.toString());
            }
            localStorage.setItem('idle_playerExp', playerExp.toString());
            updateUI();
        }, 1000);

        // ——— 监听 Pong 游戏进度事件 ———
        document.addEventListener('pong-level-update', ((e: CustomEvent) => {
            pongLevel = e.detail.level;
            pongHasStarted = true;
            pongBadgeLv = Math.min(pongLevel, 6);
            expPerSec = calculateExpRate();
            updateUI();
        }) as EventListener, { signal });

        // ——— 清理 ———
        document.addEventListener('astro:before-swap', () => {
            clearInterval(gameLoop);
            controller.abort();
        }, { once: true });
    });

    // ——— 移动端菜单 ———
    const setupMobileMenu = () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const icon = btn?.querySelector('i');

        if (!btn || !menu || !icon) return;

        btn.onclick = () => {
            const isOpen = menu.classList.contains('translate-x-0');

            if (isOpen) {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                icon.classList.remove('fa-xmark');
                icon.classList.add('fa-bars');
                document.body.style.overflow = '';
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-xmark');
                document.body.style.overflow = 'hidden';
            }
        };
    };

    setupMobileMenu();
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>