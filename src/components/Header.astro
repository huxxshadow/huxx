---
import { LOCALES, getLocalePaths, type Lang, useTranslations } from "@/i18n.ts";
import { getRelativeLocaleUrl } from "astro:i18n";
import Avatar from "@/assets/avater.svg";
import { SOCIALS, COLORS } from "@/consts.ts";
import { BADGE_CONFIGS } from "@/consts/Header.ts";
import { navTranslations, headerTooltipsTranslations } from "@/i18n/components/Header_i18.ts";

interface Props {
    bgColor?: string;
    textColor?: string;
}

const {
    bgColor = COLORS.green.light,
    textColor = COLORS.green.dark,
} = Astro.props;

const currentLocale = (Astro.currentLocale || "en") as Lang;
const localePaths = getLocalePaths(Astro.url);
const getPath = (path: string) => getRelativeLocaleUrl(currentLocale, path);
const t = useTranslations(currentLocale);

const NAV_LINKS = [
    { label: t(navTranslations.home), path: "/" },
    { label: t(navTranslations.blog), path: "/blog" },
    { label: t(navTranslations.portfolio), path: "/portfolio" },
    { label: t(navTranslations.about), path: "/aboutme" },
];
---

<header
        style={`--hdr-bg: ${bgColor}; --hdr-text: ${textColor};`}
        class="sticky top-0 z-30 w-full flex items-center justify-between px-2 sm:px-3 pt-0 font-sans"
        data-lang={currentLocale}
>
    <div class="flex items-center gap-2 sm:gap-4">
        <div class="h-16 sm:h-20 lg:h-28 shrink-0 flex items-center">
            <Avatar class="h-full w-auto block" fill="currentColor" />
        </div>

        <div class="flex flex-col justify-center gap-0.5 sm:gap-1">

            <div class="flex items-baseline gap-2 sm:gap-4">
                <a href={getPath("/")} class="nav-link-animated text-[2rem]  lg:text-[2.7rem] font-black tracking-wider leading-none">
                    huxx
                </a>

                <div class="hidden lg:block w-1 h-10 bg-current rounded-sm self-center"></div>

                <nav class="hidden lg:flex items-baseline gap-3 text-[2.1rem]">
                    {
                        SOCIALS.map((item) => (
                                <a
                                        href={item.href}
                                        class="social-link hover:opacity-80 transition-opacity"
                                        aria-label={item.name}
                                >
                                    <i class={`fa-brands ${item.icon}`}></i>
                                </a>
                        ))
                    }
                </nav>
            </div>

            {/* ——— 桌面端：经验值 / 等级 / 徽章 ——— */}
            <div class="hidden lg:flex items-center gap-1.5 sm:gap-3 flex-nowrap">
                {/* Level */}
                <div class="relative group flex items-center cursor-help">
                    <span id="player-level" class="font-bold text-base tracking-wider">Lv 0</span>
                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                        <div class="hdr-tooltip-reversed px-3 py-1.5 text-xs rounded-md shadow-md whitespace-nowrap font-medium">
                            {t(headerTooltipsTranslations.levelTooltip)}
                        </div>
                    </div>
                </div>

                {/* EXP Bar */}
                <div class="relative group flex items-center w-32 h-2.5 cursor-help">
                    <div class="absolute inset-0 rounded-full opacity-20 hdr-bg-text"></div>
                    <div id="player-exp-bar" class="absolute left-0 top-0 h-full rounded-full transition-all duration-500 ease-out hdr-bg-text" style="width: 0%;"></div>
                    <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                        <div class="hdr-tooltip-reversed px-3 py-1.5 text-xs rounded-md shadow-md whitespace-nowrap font-medium flex items-center gap-1">
                            <span id="player-exp-text">{t(headerTooltipsTranslations.expTooltipPrefix)} 0 / 10</span>
                        </div>
                    </div>
                </div>

                {/* EXP Rate */}
                <div id="player-exp-rate" class="font-mono text-base font-semibold opacity-80 tracking-tight">
                    +1{t(headerTooltipsTranslations.expRateSuffix)}
                </div>

                {/* Badges (desktop) */}
                {BADGE_CONFIGS.map((badge) => (
                        <div
                                id={`badge-${badge.key}-wrapper`}
                                data-badge-key={badge.key}
                                class="hidden relative group items-center cursor-help"
                        >
                        <span class="hdr-tooltip-reversed flex items-center gap-1.5 px-3 py-0.5 text-base tracking-wide font-semibold rounded-md shadow-sm w-max">
                            <i class={`${badge.icon} text-sm`}></i>
                            <span>{badge.label}</span>
                        </span>
                            <div class="absolute left-1/2 -translate-x-1/2 top-full mt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50 pointer-events-none">
                                <div class="hdr-tooltip-reversed px-3 py-2 text-xs rounded-md shadow-md whitespace-nowrap flex flex-col gap-1 font-medium">
                                    <div id={`badge-${badge.key}-tooltip-name`} class="font-bold border-b border-current/20 pb-1"></div>
                                    <div id={`badge-${badge.key}-tooltip-bonus`} class="opacity-90"></div>
                                    <div id={`badge-${badge.key}-tooltip-desc`} class="opacity-75 italic text-[11px]"></div>
                                </div>
                            </div>
                        </div>
                ))}
            </div>

        </div>
    </div>

    {/* ——— 桌面端导航 ——— */}
    <div class="hidden lg:flex items-center gap-6 text-2xl font-semibold mr-5">
        {
            NAV_LINKS.map((link) => (
                    <a href={getPath(link.path)} class="relative nav-link-animated px-1">
                        {link.label}
                    </a>
            ))
        }

        <div class="relative group">
            <button class="relative nav-link-animated flex items-center gap-1 py-2 cursor-pointer" aria-label="Language options">
                <span>{LOCALES[currentLocale].label}</span>
                <i class="fa-solid fa-chevron-down text-xs ml-1"></i>
            </button>
            <div class="absolute left-1/2 -translate-x-1/2 top-full pt-2 invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-200 z-50">
                <div class="hdr-dropdown flex flex-col shadow-sm rounded-sm py-2">
                    {
                        localePaths.map((lp) => (
                                <a href={lp.path} class="px-5 py-2 hover:bg-black/5 transition-colors text-center whitespace-nowrap">
                                    {LOCALES[lp.lang].label}
                                </a>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>

    {/* ——— 手机端菜单按钮 ——— */}
    <button
            id="mobile-menu-btn"
            class="lg:hidden relative z-50 text-2xl sm:text-3xl pr-2 focus:outline-none cursor-pointer"
            aria-label="Toggle Menu"
    >
        <i class="fa-solid fa-bars transition-transform duration-300"></i>
    </button>

    {/* ——— 手机端全屏菜单 ——— */}
    <div
            id="mobile-menu"
            class="hdr-dropdown fixed inset-0 z-40 translate-x-full transition-transform duration-300 flex flex-col items-center justify-center gap-6 text-2xl font-semibold"
    >
        {/* ——— 移动端：经验值 / 等级 / 徽章 ——— */}
        <div class="flex flex-col items-center gap-3 w-full px-8">
            <div class="flex items-center gap-3 justify-center">
                <span id="player-level-m" class="font-bold text-lg tracking-wider">Lv 0</span>

                <div class="relative w-28 h-3">
                    <div class="absolute inset-0 rounded-full opacity-20 hdr-bg-text"></div>
                    <div id="player-exp-bar-m" class="absolute left-0 top-0 h-full rounded-full transition-all duration-500 ease-out hdr-bg-text" style="width: 0%;"></div>
                </div>

                <div id="player-exp-rate-m" class="font-mono text-base font-semibold opacity-80 tracking-tight">
                    +1{t(headerTooltipsTranslations.expRateSuffix)}
                </div>
            </div>

            <div id="player-exp-text-m" class="text-sm font-medium opacity-70">
                {t(headerTooltipsTranslations.expTooltipPrefix)} 0 / 10
            </div>

            {/* Badges (mobile — inline info, no tooltip) */}
            <div class="flex items-center gap-2 flex-wrap justify-center">
                {BADGE_CONFIGS.map((badge) => (
                        <div
                                id={`badge-${badge.key}-wrapper-m`}
                                data-badge-key={badge.key}
                                class="hidden items-center"
                        >
                        <span class="hdr-tooltip-reversed flex items-center gap-1.5 px-3 py-1 text-sm tracking-wide font-semibold rounded-md shadow-sm">
                            <i class={`${badge.icon} text-xs`}></i>
                            <span>{badge.label}</span>
                            <span id={`badge-${badge.key}-info-m`} class="text-xs opacity-80"></span>
                        </span>
                        </div>
                ))}
            </div>
        </div>

        <div class="w-16 h-[2px] bg-current opacity-30"></div>

        {
            NAV_LINKS.map((link) => (
                    <a href={getPath(link.path)} class="relative nav-link-animated px-1 text-3xl">
                        {link.label}
                    </a>
            ))
        }

        <div class="w-16 h-[2px] bg-current opacity-30"></div>

        <div class="flex flex-col items-center gap-4 text-xl">
            <span class="opacity-70 text-sm tracking-widest uppercase"><i class="fa-solid fa-globe mr-1"></i> Language</span>
            <div class="flex gap-4">
                {
                    localePaths.map((lp) => (
                            <a
                                    href={lp.path}
                                    class={`px-1 transition-opacity ${
                                        lp.lang === currentLocale
                                            ? 'border-b-2 border-current opacity-100 font-bold'
                                            : 'opacity-50 hover:opacity-100'
                                    }`}
                            >
                                {LOCALES[lp.lang].label}
                            </a>
                    ))
                }
            </div>
        </div>

        <div class="flex gap-6 mt-4 text-[2.5rem]">
            {
                SOCIALS.map((item) => (
                        <a href={item.href} class="social-link hover:opacity-80 transition-opacity" aria-label={item.name}>
                            <i class={`fa-brands ${item.icon}`}></i>
                        </a>
                ))
            }
        </div>
    </div>
</header>

{/* ——— 全局样式：注册 CSS 自定义属性 ——— */}
<style is:global>
    @property --hdr-bg {
        syntax: '<color>';
        inherits: true;
        initial-value: #BDF1CD;
    }
    @property --hdr-text {
        syntax: '<color>';
        inherits: true;
        initial-value: #16A062;
    }
</style>

<style>
    header {
        background-color: var(--hdr-bg);
        color: var(--hdr-text);
        transition: --hdr-bg 0.7s ease, --hdr-text 0.7s ease;
    }
    .hdr-tooltip-reversed {
        background-color: var(--hdr-text);
        color: var(--hdr-bg);
    }
    .hdr-bg-text {
        background-color: var(--hdr-text);
    }
    .hdr-dropdown {
        background-color: var(--hdr-bg);
        color: var(--hdr-text);
    }
    .social-link:hover i {
        animation: fa-bounce 1s infinite;
        animation-timing-function: cubic-bezier(0.28, 0.84, 0.42, 1);
    }
    .nav-link-animated {
        position: relative;
        text-decoration: none;
    }
    .nav-link-animated::after {
        content: '';
        position: absolute;
        width: 100%;
        height: 2px;
        bottom: -2px;
        left: 0;
        background-color: currentColor;
        transform: scaleX(0);
        transform-origin: right;
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nav-link-animated:hover::after {
        transform: scaleX(1);
        transform-origin: left;
    }
</style>

<script>
    import { BADGE_CONFIGS, getRequiredExp } from "@/consts/Header.ts";
    import { badgeTranslations, headerTooltipsTranslations } from "@/i18n/components/Header_i18.ts";
    import type { Lang } from "@/i18n.ts";

    document.addEventListener('astro:page-load', () => {
        const header = document.querySelector('header');
        // Desktop elements
        const uiLevel = document.getElementById('player-level');
        const uiExpBar = document.getElementById('player-exp-bar');
        const uiExpText = document.getElementById('player-exp-text');
        const uiExpRate = document.getElementById('player-exp-rate');
        // Mobile elements
        const uiLevelM = document.getElementById('player-level-m');
        const uiExpBarM = document.getElementById('player-exp-bar-m');
        const uiExpTextM = document.getElementById('player-exp-text-m');
        const uiExpRateM = document.getElementById('player-exp-rate-m');

        if (!header) return;

        const controller = new AbortController();
        const { signal } = controller;

        // ——— 语言环境 ———
        const lang = (header.getAttribute('data-lang') as Lang) || 'en';
        const tHeader = headerTooltipsTranslations;

        const getExpPrefix = () => tHeader.expTooltipPrefix[lang] || tHeader.expTooltipPrefix['en'] || 'EXP:';
        const getExpRateSuffix = () => tHeader.expRateSuffix[lang] || tHeader.expRateSuffix['en'] || '/s';

        // ——— 挂机数据 ———
        let playerLevel = parseInt(localStorage.getItem('idle_playerLevel') || '0', 10);
        let playerExp = parseInt(localStorage.getItem('idle_playerExp') || '0', 10);
        let requiredExp = getRequiredExp(playerLevel);

        // ========== 通用 Badge 状态管理 ==========
        interface BadgeState {
            key: string;
            hasStarted: boolean;
            level: number;
            maxLevel: number;
            levels: Record<number, { bonusRate: number }>;
        }

        const badgeStates: Record<string, BadgeState> = {};

        BADGE_CONFIGS.forEach(badge => {
            const hasStarted =
                localStorage.getItem(badge.startedKey) === 'true' ||
                sessionStorage.getItem(badge.startedKey) === 'true';
            const rawLevel = parseInt(
                localStorage.getItem(badge.storageKey) ||
                sessionStorage.getItem(badge.storageKey) || '1', 10);

            badgeStates[badge.key] = {
                key: badge.key,
                hasStarted,
                level: hasStarted ? Math.min(rawLevel, badge.maxLevel) : 0,
                maxLevel: badge.maxLevel,
                levels: badge.levels,
            };
        });

        const calculateExpRate = () => {
            let rate = 1;
            Object.values(badgeStates).forEach(state => {
                if (state.level > 0 && state.levels[state.level]) {
                    rate += state.levels[state.level].bonusRate;
                }
            });
            return rate;
        };

        let expPerSec = calculateExpRate();

        // ========== Badge UI 更新（桌面端） ==========
        const updateBadgeDesktop = (key: string) => {
            const wrapper = document.getElementById(`badge-${key}-wrapper`);
            const tooltipName = document.getElementById(`badge-${key}-tooltip-name`);
            const tooltipBonus = document.getElementById(`badge-${key}-tooltip-bonus`);
            const tooltipDesc = document.getElementById(`badge-${key}-tooltip-desc`);

            if (!wrapper) return;

            const state = badgeStates[key];
            const i18n = badgeTranslations[key];
            if (!state || !i18n) return;

            if (state.level > 0 && state.levels[state.level]) {
                const data = state.levels[state.level];
                const levelI18n = i18n.levels?.[state.level];

                wrapper.classList.remove('hidden');
                wrapper.classList.add('flex');

                if (tooltipName && tooltipBonus && tooltipDesc && levelI18n) {
                    tooltipName.innerText = levelI18n.name?.[lang] || levelI18n.name?.['en'] || '';
                    const bonusPrefix = i18n.bonusPrefix?.[lang] || i18n.bonusPrefix?.['en'] || 'Bonus: +';
                    const unit = i18n.unit?.[lang] || i18n.unit?.['en'] || ' EXP/s';
                    tooltipBonus.innerText = `${bonusPrefix}${data.bonusRate}${unit}`;
                    tooltipDesc.innerText = levelI18n.desc?.[lang] || levelI18n.desc?.['en'] || '';
                }
            } else {
                wrapper.classList.add('hidden');
                wrapper.classList.remove('flex');
            }
        };

        // ========== Badge UI 更新（移动端 — inline info） ==========
        const updateBadgeMobile = (key: string) => {
            const wrapper = document.getElementById(`badge-${key}-wrapper-m`);
            const info = document.getElementById(`badge-${key}-info-m`);

            if (!wrapper) return;

            const state = badgeStates[key];
            const i18n = badgeTranslations[key];
            if (!state || !i18n) return;

            if (state.level > 0 && state.levels[state.level]) {
                wrapper.classList.remove('hidden');
                wrapper.classList.add('flex');

                if (info) {
                    const levelI18n = i18n.levels?.[state.level];
                    const name = levelI18n?.name?.[lang] || levelI18n?.name?.['en'] || '';
                    info.innerText = `· ${name}`;
                }
            } else {
                wrapper.classList.add('hidden');
                wrapper.classList.remove('flex');
            }
        };

        // ========== 监听所有 badge 事件 ==========
        BADGE_CONFIGS.forEach(badge => {
            document.addEventListener(badge.eventName, ((e: CustomEvent) => {
                const state = badgeStates[badge.key];
                if (!state) return;
                state.hasStarted = true;
                state.level = Math.min(e.detail.level, badge.maxLevel);
                expPerSec = calculateExpRate();
                updateUI();
            }) as EventListener, { signal });
        });

        // ============================================
        // ===== 内容驱动的 Header 主题色系统 =====
        // ============================================
        const applyHeaderTheme = (bg: string, text: string) => {
            header.style.setProperty('--hdr-bg', bg);
            header.style.setProperty('--hdr-text', text);
        };

        const themeSections = Array.from(document.querySelectorAll('[data-theme-bg]'));
        let activeThemeSection: Element | null = null;
        let isScrolling = false;

        const syncActiveSection = () => {
            if (themeSections.length === 0) return;
            const TRIGGER_Y = 100;
            let currentSection: Element | null = null;

            for (let i = themeSections.length - 1; i >= 0; i--) {
                const rect = themeSections[i].getBoundingClientRect();
                if (rect.top <= TRIGGER_Y) {
                    currentSection = themeSections[i];
                    break;
                }
            }

            if (!currentSection) currentSection = themeSections[0];

            if (currentSection !== activeThemeSection) {
                activeThemeSection = currentSection;
                const bg = currentSection.getAttribute('data-theme-bg');
                const text = currentSection.getAttribute('data-theme-text');
                if (bg && text) applyHeaderTheme(bg, text);
            }

            isScrolling = false;
        };

        if (themeSections.length > 0) {
            document.addEventListener('scroll', () => {
                if (!isScrolling) {
                    window.requestAnimationFrame(syncActiveSection);
                    isScrolling = true;
                }
            }, { passive: true, signal });
        }

        document.addEventListener('section-theme-change', ((e: CustomEvent) => {
            const { bg, text, source } = e.detail || {};
            if (!bg || !text || !(source instanceof Element)) return;

            source.setAttribute('data-theme-bg', bg);
            source.setAttribute('data-theme-text', text);

            if (source === activeThemeSection || !activeThemeSection) {
                activeThemeSection = source;
                applyHeaderTheme(bg, text);
            }
        }) as EventListener, { signal });

        // ——— 统一 UI 刷新（桌面 + 移动端） ———
        const updateUI = () => {
            const levelStr = `Lv ${playerLevel}`;
            const expWidth = `${Math.min((playerExp / requiredExp) * 100, 100)}%`;
            const expStr = `${getExpPrefix()} ${playerExp} / ${requiredExp}`;
            const rateStr = `+${expPerSec}${getExpRateSuffix()}`;

            // Desktop
            if (uiLevel) uiLevel.innerText = levelStr;
            if (uiExpBar) uiExpBar.style.width = expWidth;
            if (uiExpText) uiExpText.innerText = expStr;
            if (uiExpRate) uiExpRate.innerText = rateStr;

            // Mobile
            if (uiLevelM) uiLevelM.innerText = levelStr;
            if (uiExpBarM) uiExpBarM.style.width = expWidth;
            if (uiExpTextM) uiExpTextM.innerText = expStr;
            if (uiExpRateM) uiExpRateM.innerText = rateStr;

            // Badges — 双端更新
            Object.keys(badgeStates).forEach(key => {
                updateBadgeDesktop(key);
                updateBadgeMobile(key);
            });
        };

        // ——— 首次渲染 ———
        header.style.transition = 'none';
        syncActiveSection();
        updateUI();

        void header.offsetHeight;
        requestAnimationFrame(() => {
            header.style.transition = '';
        });

        // ——— 每秒挂机循环 ———
        const gameLoop = setInterval(() => {
            playerExp += expPerSec;
            while (playerExp >= requiredExp) {
                playerExp -= requiredExp;
                playerLevel++;
                requiredExp = getRequiredExp(playerLevel);
                localStorage.setItem('idle_playerLevel', playerLevel.toString());
            }
            localStorage.setItem('idle_playerExp', playerExp.toString());
            updateUI();
        }, 1000);

        // ——— 清理 ———
        document.addEventListener('astro:before-swap', () => {
            clearInterval(gameLoop);
            controller.abort();
        }, { once: true });
    });

    // ——— 移动端菜单 ———
    const setupMobileMenu = () => {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        const icon = btn?.querySelector('i');

        if (!btn || !menu || !icon) return;

        btn.onclick = () => {
            const isOpen = menu.classList.contains('translate-x-0');

            if (isOpen) {
                menu.classList.remove('translate-x-0');
                menu.classList.add('translate-x-full');
                icon.classList.remove('fa-xmark');
                icon.classList.add('fa-bars');
                document.body.style.overflow = '';
            } else {
                menu.classList.remove('translate-x-full');
                menu.classList.add('translate-x-0');
                icon.classList.remove('fa-bars');
                icon.classList.add('fa-xmark');
                document.body.style.overflow = 'hidden';
            }
        };
    };

    setupMobileMenu();
    document.addEventListener('astro:after-swap', setupMobileMenu);
</script>